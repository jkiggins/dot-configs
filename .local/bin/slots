#!/usr/bin/env python3

from datetime import datetime as dt
from datetime import timedelta as tdelta
import dateutil.parser
import sys
import click
import os

SLOT_FILE=os.path.expanduser("~/.local/.slot")

def start(delta):
    with open(SLOT_FILE, 'w+') as sf:
        expire = dt.now() + tdelta(seconds=60 * delta)
        sf.write(str(expire))

def stop():
    if os.path.exists(SLOT_FILE):
        os.remove(SLOT_FILE)

def query():
    outMsg = "out"
    inMsg = "in"

    if os.path.exists(SLOT_FILE):
        with open(SLOT_FILE, 'r') as sf:
            datestr = sf.read()
            expire = dateutil.parser.parse(datestr)

            if expire <= dt.now():
                print(outMsg)
                os.remove(SLOT_FILE)
            else:
                print(inMsg)
    else:
        print(outMsg)


@click.command()
@click.option('--start', "action", flag_value="start")
@click.option('--stop', "action", flag_value="stop")
@click.option('--query', "action", flag_value="query", default=True)
@click.option('--delta', '-d', default=20.0)
def main(action, delta):
    if action == "start":
        start(float(delta))
    elif action == "stop":
        stop()
    else:
        query()


if __name__ == '__main__':
    main()
